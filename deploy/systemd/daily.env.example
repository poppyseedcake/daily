# Install as /etc/daily/daily.env with mode 0640 and ownership root:daily.
# Replace every placeholder before starting the service. Do not commit secrets.
PORT=5174
HOST=127.0.0.1
ORIGIN=https://daily.example.com
BETTER_AUTH_URL=https://daily.example.com
BETTER_AUTH_SECRET=
DATABASE_URL=/var/lib/daily/daily.db

GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_MAPS_KILL_SWITCH=false
GOOGLE_ROUTES_API_KEY=replace-me
GOOGLE_ROUTES_GLOBAL_DAILY_CAP=100
GOOGLE_ROUTES_GLOBAL_MONTHLY_CAP=1000
GOOGLE_ROUTES_PER_PERSON_DAILY_LIMIT=50
GOOGLE_PLACES_API_KEY=replace-me
GOOGLE_PLACES_GLOBAL_MONTHLY_CAP=10000
GOOGLE_PLACES_PER_PERSON_DAILY_LIMIT=500
GOOGLE_MAPS_ATTRIBUTION_SECRET=
GOOGLE_MAPS_OPERATOR_ALERT_EMAIL=operator@example.com

ADMINISTRATOR_EMAIL_ALLOWLIST=operator@example.com
SCHEDULED_WORKER_OVERDUE_MINUTES=5
OPERATIONAL_RETENTION_DAYS=30

RESEND_API_KEY=replace-me
RESEND_FROM_EMAIL=daily@example.com
BACKUP_DIRECTORY=/var/backups/daily
BACKUP_RETENTION_DAYS=30
