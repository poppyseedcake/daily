# Better Auth and Google OAuth
PORT=5174
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5174
ORIGIN=http://localhost:5174
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_KILL_SWITCH=false
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GLOBAL_DAILY_CAP=100
GOOGLE_MAPS_GLOBAL_MONTHLY_CAP=1000
GOOGLE_MAPS_PER_PERSON_DAILY_LIMIT=50
GOOGLE_MAPS_ATTRIBUTION_SECRET=
GOOGLE_MAPS_OPERATOR_ALERT_EMAIL=
OPERATIONAL_RETENTION_DAYS=30

# Comma-separated verified Google emails allowed to access /admin
ADMINISTRATOR_EMAIL_ALLOWLIST=
SCHEDULED_WORKER_OVERDUE_MINUTES=5

RESEND_API_KEY=
RESEND_FROM_EMAIL=
BACKUP_DIRECTORY=/var/lib/daily/backups
BACKUP_RETENTION_DAYS=30
