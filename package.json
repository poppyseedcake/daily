{
  "name": "daily",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5174",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "start": "node --env-file=.env build",
    "prepare": "svelte-kit sync || true",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "pretest:e2e": "svelte-kit sync",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:backfill-next-summary": "vite-node src/lib/server/db/backfillNextSummaryScheduleCommand.ts",
    "worker:scheduled-delivery": "vite-node --config vite.worker.config.ts src/lib/server/runScheduledDailySummaryWorkerCommand.ts"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@lucide/svelte": "^1.21.0",
    "@opentelemetry/api": "^1.9.1",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.22.0",
    "@tailwindcss/vite": "^4.1.10",
    "better-auth": "^1.6.23",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "svelte": "^5.34.0",
    "svelte-dnd-action": "^0.9.70",
    "vite": "^6.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.3",
    "drizzle-kit": "^0.31.1",
    "svelte-check": "^4.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
